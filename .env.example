# ── EC2 connection ────────────────────────────────────────────────────────────
EC2_API_URL=https://your-ec2-internal-ip-or-domain
POLLER_API_KEY=your-shared-secret-key

# ── User assignment (one VPS = one user) ─────────────────────────────────────
ASSIGNED_BOT_ID=bot_oussema1
ASSIGNED_TELEGRAM_ID=123456789

# ── Polling intervals ─────────────────────────────────────────────────────────
POLL_INTERVAL=0.3
P2_POLL_INTERVAL_S=5.0
P2_BURST_INTERVAL_S=3.0
P2_BURST_ACTIVE_DURATION=300
P2_BURST_CALM_DURATION=60

# ── Workers ───────────────────────────────────────────────────────────────────
MAX_WORKERS=2  # only used for parallel P1+P2 fetch inside poll_user

# ── Logging ───────────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1
